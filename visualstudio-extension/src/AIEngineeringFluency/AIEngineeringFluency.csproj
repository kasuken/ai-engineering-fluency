<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <MinimumVisualStudioVersion>17.0</MinimumVisualStudioVersion>
    <VSToolsPath Condition="'$(VSToolsPath)' == ''">$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)</VSToolsPath>
    <RuntimeIdentifiers>win;win-x86;win-x64;win-arm;win-arm64</RuntimeIdentifiers>
  </PropertyGroup>
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectTypeGuids>{82b43b9b-a64c-4715-b499-d71e9ca2bd60};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <ProjectGuid>{A1B2C3D4-E5F6-A7B8-C9D0-E1F2A3B4C5D6}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>AIEngineeringFluency</RootNamespace>
    <AssemblyName>AIEngineeringFluency</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <UseCodebase>true</UseCodebase>
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>false</IncludeDebugSymbolsInVSIXContainer>
    <IncludeDebugSymbolsInLocalVSIXDeployment>false</IncludeDebugSymbolsInLocalVSIXDeployment>
    <CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
    <CopyOutputSymbolsToOutputDirectory>true</CopyOutputSymbolsToOutputDirectory>
    <StartAction>Program</StartAction>
    <StartProgram Condition="'$(DevEnvDir)' != ''">$(DevEnvDir)devenv.exe</StartProgram>
    <StartArguments>/rootsuffix Exp</StartArguments>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <!-- Source files -->
  <ItemGroup>
    <Compile Include="AIEngineeringFluencyPackage.cs" />
    <Compile Include="Commands\ShowTokenTrackerCommand.cs" />
    <Compile Include="Commands\ToolbarInfoCommand.cs" />
    <Compile Include="Options\ExtensionSettings.cs" />
    <Compile Include="Options\GeneralOptions.cs" />
    <Compile Include="Options\OptionsPage.cs" />
    <Compile Include="Data\Models.cs" />
    <Compile Include="Data\CliBridge.cs" />
    <Compile Include="Data\StatsBuilder.cs" />
    <Compile Include="Properties\Settings.Designer.cs">
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
      <DependentUpon>Settings.settings</DependentUpon>
    </Compile>
    <Compile Include="ToolWindow\TokenTrackerToolWindow.cs" />
    <Compile Include="Utilities\OutputLogger.cs" />
    <Compile Include="WebBridge\ThemedHtmlBuilder.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>
  <!-- WPF XAML -->
  <ItemGroup>
    <Page Include="ToolWindow\TokenTrackerControl.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Compile Include="ToolWindow\TokenTrackerControl.xaml.cs">
      <DependentUpon>TokenTrackerControl.xaml</DependentUpon>
    </Compile>
  </ItemGroup>
  <!-- Extension icon -->
  <ItemGroup>
    <Content Include="assets\logo.png">
      <IncludeInVSIX>true</IncludeInVSIX>
      <VSIXSubPath>assets\</VSIXSubPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- Unified Settings manifest (VS 2022 17.9+) -->
    <Content Include="AIEngineeringFluency.registration.json">
      <IncludeInVSIX>true</IncludeInVSIX>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- pkgdef fragment that registers the Unified Settings manifest -->
    <Content Include="UnifiedSettings.pkgdef">
      <IncludeInVSIX>true</IncludeInVSIX>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <!-- VSIX manifest -->
  <ItemGroup>
    <None Include="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
    <None Include="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
    </None>
  </ItemGroup>
  <!-- VSCT: VS Command Table definition (menus / commands) -->
  <ItemGroup>
    <VSCTCompile Include="AIEngineeringFluencyPackage.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>
  <!-- Embedded resources -->
  <ItemGroup>
    <EmbeddedResource Include="WebBridge\vscode-shim.js" />
  </ItemGroup>
  <!-- Framework references -->
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Design" />
    <Reference Include="System.Drawing" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="WindowsBase" />
    <Reference Include="System.Xaml" />
  </ItemGroup>
  <!-- NuGet packages -->
  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.6.36389" ExcludeAssets="runtime" NoWarn="NU1604" />
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="17.6.2164" NoWarn="NU1604" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2478.35" />
    <PackageReference Include="Community.VisualStudio.Toolkit" Version="17.0.76.303" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets" Condition="'$(VSToolsPath)' != ''" />
  <!--
    Clear the experimental-instance MEF / command-table cache so VSCT and
    package-registration changes are always picked up on F5.
    Only runs in Debug builds. Safe to fail (e.g. first run, no Exp hive yet).
  -->
  <Target Name="ClearExpCache" BeforeTargets="Build" Condition="'$(Configuration)' == 'Debug'">
    <Exec Command="for /d %%d in (&quot;$(LocalAppData)\Microsoft\VisualStudio\17.0_*Exp&quot;) do ( if exist &quot;%%d\ComponentModelCache&quot; rd /s /q &quot;%%d\ComponentModelCache&quot; )"
          IgnoreExitCode="true"
          ContinueOnError="true" />
    <Message Importance="high" Text="Cleared experimental-instance ComponentModelCache." />
  </Target>

  <!--
    Copy webview JS bundles from the vscode-extension build output into this project's
    webview\ folder so they can be packaged inside the VSIX.
    Prerequisite: run `npm run compile` in vscode-extension/ first.
  -->
  <Target Name="CopyWebviewBundles" BeforeTargets="Build">
    <ItemGroup>
      <_WebviewBundle Include="..\..\..\vscode-extension\dist\webview\details.js" />
      <_WebviewBundle Include="..\..\..\vscode-extension\dist\webview\chart.js" />
      <_WebviewBundle Include="..\..\..\vscode-extension\dist\webview\usage.js" />
      <_WebviewBundle Include="..\..\..\vscode-extension\dist\webview\diagnostics.js" />
      <_WebviewBundle Include="..\..\..\vscode-extension\dist\webview\environmental.js" />
      <_WebviewBundle Include="..\..\..\vscode-extension\dist\webview\maturity.js" />
      <_WebviewBundle Include="..\..\..\vscode-extension\dist\webview\tokenEstimators.json" />
      <_WebviewBundle Include="..\..\..\vscode-extension\dist\webview\modelPricing.json" />
      <_WebviewBundle Include="..\..\..\vscode-extension\dist\webview\toolNames.json" />
      <_WebviewBundle Include="..\..\..\vscode-extension\dist\webview\automaticTools.json" />
    </ItemGroup>
    <!--
      Warn loudly when the freshly-built bundles are absent. Without this, the Copy below
      silently no-ops (ContinueOnError) and the VSIX ships the committed webview\*.js, which
      can be weeks out of date — the root cause of missing icons / friendly model names /
      "Other models" grouping in past releases. Build vscode-extension first (npm run package)
      or use ./build.ps1 -Project visualstudio, which rebuilds the bundles automatically.
    -->
    <Warning
      Condition="!Exists('..\..\..\vscode-extension\dist\webview\details.js')"
      Text="vscode-extension/dist/webview bundles not found — packaging the committed (possibly STALE) webview\*.js. Run 'npm run package' in vscode-extension/ or build via ./build.ps1 -Project visualstudio." />
    <Warning
      Condition="!Exists('$(MSBuildProjectDirectory)\cli-bundle\copilot-token-tracker.exe')"
      Text="cli-bundle/copilot-token-tracker.exe not found — the VSIX will have NO bundled CLI and will show empty/zero usage data. Run ./build.ps1 -Project visualstudio to build and copy the CLI exe." />
    <MakeDir Directories="$(MSBuildProjectDirectory)\webview" />
    <Copy SourceFiles="@(_WebviewBundle)" DestinationFolder="$(MSBuildProjectDirectory)\webview\" SkipUnchangedFiles="true" ContinueOnError="true" />
    <Message Importance="high" Text="Copied webview bundles from vscode-extension/dist/webview/ — rebuild vscode-extension if they are missing." />

  </Target>
  <!-- Include copied webview JS files inside the VSIX package -->
  <ItemGroup>
    <Content Include="webview\*.js" Condition="Exists('$(MSBuildProjectDirectory)\webview')">
      <IncludeInVSIX>true</IncludeInVSIX>
      <VSIXSubPath>webview\</VSIXSubPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="webview\*.json" Condition="Exists('$(MSBuildProjectDirectory)\webview')">
      <IncludeInVSIX>true</IncludeInVSIX>
      <VSIXSubPath>webview\</VSIXSubPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <!--
    Copy cli-bundle files to the output directory so the extension DLL can find them
    when loaded from bin\Debug or bin\Release (not from the VSIX).
    VSIX packaging is handled separately by the AddCliBundleToVsix target below.
  -->
  <ItemGroup>
    <Content Include="$(MSBuildProjectDirectory)\cli-bundle\copilot-token-tracker.exe"
             Condition="Exists('$(MSBuildProjectDirectory)\cli-bundle\copilot-token-tracker.exe')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>cli-bundle\copilot-token-tracker.exe</Link>
    </Content>
    <Content Include="$(MSBuildProjectDirectory)\cli-bundle\sql-wasm.wasm"
             Condition="Exists('$(MSBuildProjectDirectory)\cli-bundle\sql-wasm.wasm')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>cli-bundle\sql-wasm.wasm</Link>
    </Content>
  </ItemGroup>

  <!--
    Add the bundled CLI exe and associated wasm into the VSIX by directly injecting
    VSIXSourceItem entries immediately before GetVsixSourceItems collects them.

    Why BeforeTargets="GetVsixSourceItems" and NOT BeforeTargets="Build":
      CreateVsixContainer is triggered by PrepareForRun (not Build). The CopyWebviewBundles
      target (BeforeTargets="Build") does NOT run in the PrepareForRun path, so any Content
      items added there are invisible to GetVsixSourceItems.

    Why we also delete $(FileManifest) (files.json):
      GenerateFileManifest has only Outputs (no Inputs), so it is skipped whenever
      files.json already exists — even if the item list has changed. Deleting it here
      (when cli-bundle is present) forces GenerateFileManifest to regenerate files.json
      with the cli-bundle entries included, so VsixUtil packages them correctly.
  -->
  <Target Name="AddCliBundleToVsix" BeforeTargets="GetVsixSourceItems">
    <!-- Force files.json to regenerate so cli-bundle entries are included. -->
    <Delete Files="$(FileManifest)"
            Condition="Exists('$(MSBuildProjectDirectory)\cli-bundle\copilot-token-tracker.exe') AND Exists('$(FileManifest)')" />
    <ItemGroup>
      <VSIXSourceItem Include="$(MSBuildProjectDirectory)\cli-bundle\copilot-token-tracker.exe"
                      Condition="Exists('$(MSBuildProjectDirectory)\cli-bundle\copilot-token-tracker.exe')">
        <VSIXSubPath>cli-bundle\</VSIXSubPath>
      </VSIXSourceItem>
      <VSIXSourceItem Include="$(MSBuildProjectDirectory)\cli-bundle\sql-wasm.wasm"
                      Condition="Exists('$(MSBuildProjectDirectory)\cli-bundle\sql-wasm.wasm')">
        <VSIXSubPath>cli-bundle\</VSIXSubPath>
      </VSIXSourceItem>
    </ItemGroup>
  </Target>
</Project>
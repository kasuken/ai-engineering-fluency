# Enforce consistent line endings across platforms
# Default: LF for all text files
* text=auto eol=lf

# Windows script files should use CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# jetbrains-plugin gradlew.bat override: keep LF (not CRLF) to prevent
# git stash/pop conflicts on Linux runners (see PR #1463 / issue #1445)
jetbrains-plugin/gradlew.bat text

# Keep images and binaries untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text
*.ico binary
*.zip binary
*.gz binary
*.tar binary
*.pdf binary
